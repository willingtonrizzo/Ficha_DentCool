{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DentCool",
  "version": "0.1.0",
  "identifier": "com.dentcool.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "DentCool",
        "width": 1400,
        "height": 920,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    }
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:ficha-dentcool.db"]
    }
  }
}
